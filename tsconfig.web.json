{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/env.d.ts",
    "src/renderer/**/*",
    "src/renderer/**/*.tsx",
    "src/preload/*.d.ts",
    "src/preload/electron.d.ts",
    "src/@types/**/*"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "node",
      "electron-vite/node",
      "vitest/globals",
      "@testing-library/jest-dom"
    ],
    "composite": true,
    "paths": {
      "@/*": ["./src/*"],
      "@sleek-types": ["./src/@types/index"]
    }
  }
}
